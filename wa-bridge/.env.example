# WA Bridge Configuration
PORT=3001

# Secret key untuk autentikasi (samakan dengan backend utama)
WA_BRIDGE_SECRET=cahaya-phone-secret-key

# URL webhook backend utama (untuk forward pesan masuk)
# Contoh: https://cahaya-phone.vercel.app/api/webhook/whatsapp
WEBHOOK_URL=

# Auto-reply settings
AUTO_REPLY_ENABLED=true
AUTO_REPLY_MESSAGE=Halo {nama}, terima kasih sudah menghubungi Cahaya Phone! Tim kami akan segera membantu Anda.
